<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.openclaw.doterra-scraper</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/node</string>
        <string>/Users/mac/.openclaw/workspace/doterra-scraper.js</string>
    </array>
    
    <key>StartCalendarInterval</key>
    <array>
        <!-- Daily at 6 AM (all days) -->
        <dict>
            <key>Hour</key>
            <integer>6</integer>
            <key>Minute</key>
            <integer>0</integer>
        </dict>
        <!-- Last 2 days of month: every 5 hours -->
        <!-- 11 AM on 30th & 31st -->
        <dict>
            <key>Hour</key>
            <integer>11</integer>
            <key>Minute</key>
            <integer>0</integer>
            <key>Day</key>
            <integer>30</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>11</integer>
            <key>Minute</key>
            <integer>0</integer>
            <key>Day</key>
            <integer>31</integer>
        </dict>
        <!-- 4 PM on 30th & 31st -->
        <dict>
            <key>Hour</key>
            <integer>16</integer>
            <key>Minute</key>
            <integer>0</integer>
            <key>Day</key>
            <integer>30</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>16</integer>
            <key>Minute</key>
            <integer>0</integer>
            <key>Day</key>
            <integer>31</integer>
        </dict>
        <!-- 9 PM on 30th & 31st -->
        <dict>
            <key>Hour</key>
            <integer>21</integer>
            <key>Minute</key>
            <integer>0</integer>
            <key>Day</key>
            <integer>30</integer>
        </dict>
        <dict>
            <key>Hour</key>
            <integer>21</integer>
            <key>Minute</key>
            <integer>0</integer>
            <key>Day</key>
            <integer>31</integer>
        </dict>
    </array>
    
    <key>StandardOutPath</key>
    <string>/Users/mac/.openclaw/workspace/doterra-cron.log</string>
    
    <key>StandardErrorPath</key>
    <string>/Users/mac/.openclaw/workspace/doterra-cron.err</string>
    
    <key>WorkingDirectory</key>
    <string>/Users/mac/.openclaw/workspace</string>
    
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>/Users/mac</string>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    
    <key>RunAtLoad</key>
    <false/>
    
    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
